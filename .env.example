# ---------------------------------------------------------
# CORE SETUP
# ---------------------------------------------------------

# Get your Discord Bot Token here: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Get your Last.fm API Key here: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_API_SECRET=your_lastfm_api_secret_here
BOT_LASTFM_SESSION_KEY=your_bot_lastfm_session_key_here

# ---------------------------------------------------------
# DATABASE (PostgreSQL)
# ---------------------------------------------------------

# You can get a free Postgres database from https://supabase.com or https://neon.tech
DATABASE_URL=your_postgres_database_url_here
POSTGRES_URL=your_postgres_database_url_here_alternative

# ---------------------------------------------------------
# AI / JUDGING APIs
# ---------------------------------------------------------

# Get your free Groq API key here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get your free Google Gemini API key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
